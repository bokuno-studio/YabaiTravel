{
  "name": "yabai-travel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run db:migrate && node scripts/generate-sitemap.js; tsc -b && vite build && npm run build:ssr",
    "build:skip-db": "node scripts/generate-sitemap.js; tsc -b && vite build && npm run build:ssr",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/build-ssr-handler.js",
    "preview:ssr": "node server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:migrate": "node scripts/run-migration.js",
    "db:seed": "node scripts/seed-events.js",
    "db:reset": "node scripts/reset-db.js",
    "extract:test": "node scripts/crawl-extract/run-extract.js",
    "crawl:run": "node scripts/crawl/run.js",
    "crawl:collect": "node scripts/crawl/collect-races.js",
    "crawl:orchestrate": "node scripts/crawl/orchestrator.js",
    "crawl:fetch-all": "node scripts/crawl/fetch-all-urls.js",
    "crawl:fix-and-rerun": "node scripts/crawl/fix-and-rerun.js && npm run crawl:run",
    "crawl:reset-retry": "node scripts/crawl/reset-retry.js",
    "report:daily": "node scripts/crawl/daily-report-ondemand.js",
    "deploy:watch": "sh scripts/watch-deploy.sh",
    "knip": "knip",
    "license-check": "license-checker --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;0BSD;CC0-1.0;CC-BY-4.0;Unlicense;MPL-2.0' --summary",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@react-google-maps/api": "^2.20.8",
    "@sentry/react": "^10.45.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vis.gl/react-google-maps": "^1.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.16",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "globals": "^16.5.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^6.0.0",
    "license-checker": "^25.0.1",
    "pg": "^8.20.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
