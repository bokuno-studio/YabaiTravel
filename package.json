{
  "name": "yabai-travel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run db:migrate && tsc -b && vite build",
    "build:skip-db": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:migrate": "node scripts/run-migration.js",
    "db:seed": "node scripts/seed-events.js",
    "db:reset": "node scripts/reset-db.js",
    "extract:test": "node scripts/crawl-extract/run-extract.js",
    "crawl:run": "node scripts/crawl/run.js",
    "crawl:collect": "node scripts/crawl/collect-races.js",
    "crawl:orchestrate": "node scripts/crawl/orchestrator.js",
    "crawl:fetch-all": "node scripts/crawl/fetch-all-urls.js",
    "crawl:fix-and-rerun": "node scripts/crawl/fix-and-rerun.js && npm run crawl:run",
    "deploy:watch": "sh scripts/watch-deploy.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.98.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "pg": "^8.20.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
