# .env ファイルのコミット防止
ENV_FILES=$(git diff --cached --name-only | grep -E '^\.(env|env\..*)$' || true)
if [ -n "$ENV_FILES" ]; then
  echo "ERROR: .env file(s) staged for commit:"
  echo "$ENV_FILES"
  echo ""
  echo "Remove them with: git reset HEAD <file>"
  exit 1
fi

# .gitignore に .env* が含まれているか確認
if ! grep -q '\.env' .gitignore 2>/dev/null; then
  echo "WARNING: .gitignore does not contain .env pattern"
  exit 1
fi

npm run lint
