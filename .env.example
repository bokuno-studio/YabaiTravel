# Supabase（.env.local にコピーして値を入れる）
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# スキーマ名（本番: yabai_travel / ステージング: yabai_travel_staging）
VITE_SUPABASE_SCHEMA=yabai_travel

# サーバーサイド専用（フロントに露出させないこと）
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API（スキーマ作成・PostgREST設定変更など DDL 操作用）
# https://supabase.com/dashboard/account/tokens で発行
SUPABASE_ACCESS_TOKEN=sbp_xxx...
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx

# Claude API（クロール・抽出用）
ANTHROPIC_API_KEY=

# Tavily Search API（欠落情報の Web 検索補完用）
# https://app.tavily.com でキー発行
TAVILY_API_KEY=

# Mapbox（地図表示用）
# https://account.mapbox.com/access-tokens/ で発行
VITE_MAPBOX_TOKEN=

# SQL実行用（クロールスクリプト・マイグレーション用）
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-xx.pooler.supabase.com:6543/postgres
