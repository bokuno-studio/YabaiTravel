# Supabase（.env.local にコピーして値を入れる）
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# サーバーサイド専用（フロントに露出させないこと）
SUPABASE_SERVICE_ROLE_KEY=

# SQL実行用（スキーマ作成等）。Supabase Dashboard > Database > Connection string
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-xx.pooler.supabase.com:6543/postgres
