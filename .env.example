# Supabase（.env.local にコピーして値を入れる）
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# スキーマ名（本番: yabai_travel / ステージング: yabai_travel_staging）
VITE_SUPABASE_SCHEMA=yabai_travel

# サーバーサイド専用（フロントに露出させないこと）
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API（スキーマ作成・PostgREST設定変更など DDL 操作用）
SUPABASE_ACCESS_TOKEN=sbp_xxx...
SUPABASE_PROJECT_REF=xxxxxxxxxxxxxxxx

# Claude API（クロール・抽出用）
ANTHROPIC_API_KEY=

# Tavily Search API（欠落情報の Web 検索補完用）
TAVILY_API_KEY=

# Google Maps（地図表示・ルート検索用）
VITE_GOOGLE_MAPS_KEY=
GOOGLE_DIRECTIONS_API_KEY=

# SQL実行用（クロールスクリプト・マイグレーション用）
DATABASE_URL=

# Square 決済（本番）
VITE_SQUARE_APP_ID=sq0idp-xxx
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Vercel Team
VERCEL_TOKEN=

# Telegram Bot（デイリーレポート配信用）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 楽天トラベル アフィリエイト
VITE_RAKUTEN_AFFILIATE_ID=

# Sentry（エラー監視）
VITE_SENTRY_DSN=
